# ==========================================
# Altus - Global Gitignore
# ==========================================

# Logs & Système
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.DS_Store
Thumbs.db

# IDEs and Editors
.vscode/
.idea/
*.swp
*.swo
*.suo

# ==========================================
# FRONTEND (React / Vite)
# ==========================================
frontend/node_modules/
frontend/dist/
frontend/dist-ssr/
frontend/.env
frontend/.env.local
frontend/.env.*.local

# ==========================================
# BACKEND (FastAPI / Python)
# ==========================================
backend/venv/
backend/.venv/
backend/__pycache__/
backend/*.pyc
backend/*.pyo
backend/*.pyd
backend/.env

# ==========================================
# SCANNER (Go)
# ==========================================
scanner/scanner.exe
scanner/*.exe
scanner/*.test
scanner/*.prof
=======